      "versionNonce": 20808,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "4. Quality / Dedup / Safety\nTier 1: exact hash dedup\nTier 2: rule quality gates: corrupt files, silence, short text\nTier 3: FAISS ANN near-dedup\nTier 4: safety classifiers",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. Quality / Dedup / Safety\nTier 1: exact hash dedup\nTier 2: rule quality gates: corrupt files, silence, short text\nTier 3: FAISS ANN near-dedup\nTier 4: safety classifiers",
      "lineHeight": 1.2,
      "baseline": 92
    },
