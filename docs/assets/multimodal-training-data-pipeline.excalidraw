      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "9. Training Loader\nStreaming dequeue with prefetch\nDeterministic shuffle and worker partitioning\nMid-epoch resume from shard id + offset",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "9. Training Loader\nStreaming dequeue with prefetch\nDeterministic shuffle and worker partitioning\nMid-epoch resume from shard id + offset",
      "lineHeight": 1.2,
      "baseline": 82
