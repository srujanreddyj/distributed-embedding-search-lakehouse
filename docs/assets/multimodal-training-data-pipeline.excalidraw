    {
      "id": "text-03-preprocessing",
      "type": "text",
      "x": 250,
      "y": 574,
      "width": 680,
      "height": 86,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
