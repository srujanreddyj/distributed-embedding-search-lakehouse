      "versionNonce": 20404,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "2. Content-Addressed Store (CAS)\nRaw files keyed by SHA256 hash\nTwo-level prefix layout: sha[:2] / sha[2:4] / sha.ext",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Content-Addressed Store (CAS)\nRaw files keyed by SHA256 hash\nTwo-level prefix layout: sha[:2] / sha[2:4] / sha.ext",
      "lineHeight": 1.2,
      "baseline": 72
    },
