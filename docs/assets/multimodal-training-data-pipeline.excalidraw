      "updated": 1,
      "link": null,
      "locked": false,
      "text": "8. Materialization\nPack manifests into WebDataset tar shards\nSequential streaming layout for efficient training reads",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "8. Materialization\nPack manifests into WebDataset tar shards\nSequential streaming layout for efficient training reads",
      "lineHeight": 1.2,
