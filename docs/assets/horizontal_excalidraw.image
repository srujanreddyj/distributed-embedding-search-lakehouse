    {
      "id": "text-01-source-connectors",
      "type": "text",
      "x": 100,
      "y": 238,
      "width": 340,
      "height": 86,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 202,
      "version": 2,
      "versionNonce": 20202,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "1. Source Connectors\nHuggingFace ingestion: FineWeb-Edu text, COCO images,\nMSR-VTT video, LibriSpeech audio\nOutput: uniform manifests with source ids and payload pointers",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Source Connectors\nHuggingFace ingestion: FineWeb-Edu text, COCO images,\nMSR-VTT video, LibriSpeech audio\nOutput: uniform manifests with source ids and payload pointers",
      "lineHeight": 1.2,
      "baseline": 82
    },
