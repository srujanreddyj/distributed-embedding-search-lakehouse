      "version": 2,
      "versionNonce": 20606,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "3. Preprocessing Engine\nRay Data map_batches with stateful actors per modality\nMiniLM for text, CLIP for images/video, Whisper for audio\nBatch decode, normalize, tokenize, and emit embeddings/features",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. Preprocessing Engine\nRay Data map_batches with stateful actors per modality\nMiniLM for text, CLIP for images/video, Whisper for audio\nBatch decode, normalize, tokenize, and emit embeddings/features",
      "lineHeight": 1.2,
      "baseline": 82
    },
